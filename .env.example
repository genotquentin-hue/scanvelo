# Copie ce fichier en .env et remplis les valeurs (ne commite JAMAIS .env)

# --- Telegram (alertes instantanées) ---
# 1. Sur Telegram, parle à @BotFather → /newbot → récupère le token
# 2. Pour le CHAT_ID : parle à ton bot, puis ouvre
#    https://api.telegram.org/bot<TON_TOKEN>/getUpdates et copie le "chat":{"id":...}
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# --- Gmail (récap quotidien par email) ---
# Génère un "mot de passe d'application" sur https://myaccount.google.com/apppasswords
# (nécessite la validation en 2 étapes activée). Ce n'est PAS ton mot de passe Google normal.
GMAIL_USER=genot.quentin@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_TO=genot.quentin@gmail.com

# --- Analyse IA (optionnel — sans clé, toutes les annonces sont notifiées) ---
# Crée une clé sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
